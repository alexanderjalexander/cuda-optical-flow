CompileFlags:
  Remove:
    - "-x*"
    - "--cuda*"
    - "-fcuda*"
    - "--offload*"
  Add:
    - "-xc++"
    - "-std=c++17"
    - "-I/usr/local/cuda-13.2/include"
    - "-I/usr/include/opencv4"
    - "-D__CUDACC__"
    - "-D__CUDA_ARCH__=860"
    - "-D__host__="
    - "-D__device__="
    - "-D__global__="
    - "-D__forceinline__=inline"